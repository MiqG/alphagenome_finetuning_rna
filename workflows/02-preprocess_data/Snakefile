"""
Preprocessing workflow: select BED intervals for overfitting experiments.

Reads FOLD_1 intervals, scores them by splice junction activity (total
uniquely-mapped junction reads across PREP_SAMPLES from STAR SJ.out.tab
files), and writes:

  single intervals  — one BED per density tier (high / medium / low)
                      used by 03-overfitting_single

Run with:
    snakemake -s workflows/02-preprocess_data/Snakefile --use-conda [-n]
"""

import os

configfile: "config/config.yaml"

PREP_CFG  = config["preprocessing"]["overfitting"]
FOLDS_DIR = config["finetuning"]["alphagenome"]["folds_dir"]
DATA_DIR  = config["rnaseq"]["sf3b1mut"]["path"]

SAMPLES    = PREP_CFG["samples"]
FOLD       = PREP_CFG["fold"]
DENSITIES  = PREP_CFG["single"]["densities"]
SINGLE_DIR = PREP_CFG["single"]["output_dir"]

STAR_JUNCTIONS = [
    os.path.join(DATA_DIR, "STAR", s, "paper_pass.SJ.out.tab")
    for s in SAMPLES
]

WEIGHTS = config["alphagenome_pytorch"]["paths"]["weights"]
GENOME  = config["gencode"]["paths"]["fasta"]
SEQ_LEN = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"]

_FWD_OUTPUTS = ["rna_seq.npz", "splice_classification.npz", "splice_usage.npz", "splice_junctions.npz", "splice_junctions_annotated.npz", "metadata.json"]

rule all:
    input:
        os.path.join(SINGLE_DIR, "interval_ranking.tsv.gz"),
        expand(os.path.join(SINGLE_DIR, "{density}.bed"), density=DENSITIES),
        expand(os.path.join(SINGLE_DIR, "{density}", "{f}"), density=DENSITIES, f=_FWD_OUTPUTS),


rule rank_intervals:
    """Rank all FOLD train intervals by splice junction activity and write the table."""
    input:
        bed            = os.path.join(FOLDS_DIR, FOLD, "train.bed"),
        star_junctions = STAR_JUNCTIONS,
    output:
        ranking = os.path.join(SINGLE_DIR, "interval_ranking.tsv.gz"),
    params:
        script  = "src/scripts/select_density_intervals.py",
        density = "high",
    conda:
        "alphagenome_finetuning_rna"
    shell:
        """
        python {params.script} \
            --bed {input.bed} \
            --star-junctions {input.star_junctions} \
            --density {params.density} \
            --output-ranking {output.ranking}
        """


rule select_single_intervals:
    """Select one interval per density tier (high/medium/low) from FOLD train.bed."""
    wildcard_constraints:
        density = "high|medium|low",
    input:
        bed            = os.path.join(FOLDS_DIR, FOLD, "train.bed"),
        star_junctions = STAR_JUNCTIONS,
    output:
        bed = os.path.join(SINGLE_DIR, "{density}.bed"),
    params:
        script  = "src/scripts/select_density_intervals.py",
        density = "{density}",
    conda:
        "alphagenome_finetuning_rna"
    shell:
        """
        python {params.script} \
            --bed {input.bed} \
            --star-junctions {input.star_junctions} \
            --density {params.density} \
            --output {output.bed}
        """


rule pretrained_forward_pass_single:
    """Run pretrained AlphaGenome forward pass on each single density interval."""
    wildcard_constraints:
        density = "high|medium|low",
    input:
        bed            = os.path.join(SINGLE_DIR, "{density}.bed"),
        weights        = WEIGHTS,
        genome         = GENOME,
        star_junctions = STAR_JUNCTIONS,
    output:
        rna_seq             = os.path.join(SINGLE_DIR, "{density}", "rna_seq.npz"),
        classification      = os.path.join(SINGLE_DIR, "{density}", "splice_classification.npz"),
        usage               = os.path.join(SINGLE_DIR, "{density}", "splice_usage.npz"),
        junctions           = os.path.join(SINGLE_DIR, "{density}", "splice_junctions.npz"),
        junctions_annotated = os.path.join(SINGLE_DIR, "{density}", "splice_junctions_annotated.npz"),
        metadata            = os.path.join(SINGLE_DIR, "{density}", "metadata.json"),
    params:
        script  = "src/scripts/run_pretrained_forward_pass.py",
        out_dir = os.path.join(SINGLE_DIR, "{density}"),
        seq_len = SEQ_LEN,
    conda:
        "alphagenome_pytorch"
    shell:
        """
        python {params.script} \
            --weights {input.weights} \
            --bed {input.bed} \
            --genome {input.genome} \
            --sequence-length {params.seq_len} \
            --output-dir {params.out_dir} \
            --star-junctions {input.star_junctions}
        """
