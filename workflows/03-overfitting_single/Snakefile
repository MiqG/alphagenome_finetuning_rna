"""
Overfitting workflow: fine-tune AlphaGenome on 3 single density-tier intervals.

Depends on outputs from 02-preprocess_data (data/prep/overfitting/single/{density}.bed).
Each interval is overfitted independently for 50 epochs (constant LR, linear-probe mode)
using paper_pass bigwigs and junction files from the 2 preprocessing samples.

Three experiment groups, each run on high / medium / low density intervals:

  original            — baseline (randinit, no segmented loss, no GTF):
                        5 modality-weight configs (all + 4 individual)

  debug_splice_sites  — ablate head_init x segmented_loss x GTF:
                        6 selected configs x 2 modality-weight sets

  debug_splice_junctions — ablate rope_init x GTF:
                        4 configs x 2 modality-weight sets

Run with:
    snakemake -s workflows/03-overfitting_single/Snakefile --use-conda [-n]
"""

import os

configfile: "config/config.yaml"

DATA_DIR        = config["rnaseq"]["sf3b1mut"]["path"]
FINETUNE_SCRIPT = config["finetuning"]["alphagenome"]["finetune_script"]
SINGLE_BED_DIR  = config["preprocessing"]["overfitting"]["single"]["output_dir"]
OUTPUT_DIR      = "results/finetuning/alphagenome_pytorch/overfitting/single"

SAMPLES        = config["preprocessing"]["overfitting"]["samples"]
DENSITIES      = config["preprocessing"]["overfitting"]["single"]["densities"]
BIGWIG_STRANDS = ["forward", "reverse"]

# ---------------------------------------------------------------------------
# Run configuration
# Each entry: modality_weights, init_strategy, use_gtf, loss_partitions, rope
# ---------------------------------------------------------------------------

_ALL_MW  = "rna_seq:1.0,splice_site:1.0,splice_usage:1.0,splice_junctions:1.0"
_SS_MW   = "rna_seq:0.0,splice_site:1.0,splice_usage:0.0,splice_junctions:0.0"
_SJ_MW   = "rna_seq:0.0,splice_site:0.0,splice_usage:0.0,splice_junctions:1.0"
_ORIGINAL_RUNS = {
    "original__all": {
        "modality_weights": _ALL_MW,
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    },
    "original__rna_seq_only": {
        "modality_weights": "rna_seq:1.0,splice_site:0.0,splice_usage:0.0,splice_junctions:0.0",
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    },
    "original__splice_site_only": {
        "modality_weights": _SS_MW,
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    },
    "original__splice_usage_only": {
        "modality_weights": "rna_seq:0.0,splice_site:0.0,splice_usage:1.0,splice_junctions:0.0",
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    },
    "original__splice_junctions_only": {
        "modality_weights": _SJ_MW,
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    },
}

# 6 (head_init x segmented_loss x gtf_variant) configs x 2 modality-weight sets
_SS_CONFIGS = [
    ("randinit_noseg_gtf",  "normal",     None, True),
    ("randinit_seg_gtf",    "normal",     8,    True),
    ("randinit_seg_nogtf",  "normal",     8,    False),
    ("pretrinit_seg_nogtf", "pretrained", 8,    False),
    ("pretrinit_seg_gtf",   "pretrained", 8,    True),
    ("pretrinit_noseg_gtf", "pretrained", None, True),
]

_DEBUG_SS_RUNS = {}
for _cfg, _init, _ns, _gtf in _SS_CONFIGS:
    for _mod_suffix, _mw in [("all", _ALL_MW), ("splice_site_only", _SS_MW)]:
        _key = "debug_splice_sites__{}__{}" .format(_cfg, _mod_suffix)
        _DEBUG_SS_RUNS[_key] = {
            "modality_weights": _mw,
            "init_strategy":    _init,
            "use_gtf":          _gtf,
            "num_segments":     _ns,
            "rope":             "original",
        }

# 4 (rope_variant x gtf_variant) configs x 2 modality-weight sets
_SJ_CONFIGS = [
    ("origrope_gtf",   "original",  True),
    ("origrope_nogtf", "original",  False),
    ("truncrope_gtf",  "truncated", True),
    ("truncrope_nogtf","truncated", False),
]

_DEBUG_SJ_RUNS = {}
for _cfg, _rope, _gtf in _SJ_CONFIGS:
    for _mod_suffix, _mw in [("all", _ALL_MW), ("junction_only", _SJ_MW)]:
        _key = "debug_splice_junctions__{}__{}" .format(_cfg, _mod_suffix)
        _DEBUG_SJ_RUNS[_key] = {
            "modality_weights": _mw,
            "init_strategy":    "normal",
            "use_gtf":          _gtf,
            "num_segments":     None,
            "rope":             _rope,
        }

ALL_RUNS = {}
ALL_RUNS.update(_ORIGINAL_RUNS)
#ALL_RUNS.update(_DEBUG_SS_RUNS)
#ALL_RUNS.update(_DEBUG_SJ_RUNS)

_GROUP_RUNS = {
    "original":               list(_ORIGINAL_RUNS.keys()),
    #"debug_splice_sites":     list(_DEBUG_SS_RUNS.keys()),
    #"debug_splice_junctions": list(_DEBUG_SJ_RUNS.keys()),
}


# ---------------------------------------------------------------------------
# Parameter helper functions
# ---------------------------------------------------------------------------

def _modality_weights(wildcards):
    return ALL_RUNS[wildcards.run_name]["modality_weights"]


def _pretrained_head_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["init_strategy"] == "pretrained":
        return (
            "--pretrained-head-samples rna_seq:119,splice_usage:139,splice_junctions:139,splice_site:0"
            " --organism human"
        )
    return "--pretrained-head-samples rna_seq:NA,splice_usage:NA,splice_junctions:NA,splice_site:NA --organism human"


def _gtf_arg(wildcards, input):
    if ALL_RUNS[wildcards.run_name]["use_gtf"]:
        return "--gtf {}".format(input.gtf_parquet)
    return ""


def _num_segments_arg(wildcards):
    ns = ALL_RUNS[wildcards.run_name]["num_segments"]
    return "--num-segments {}".format(ns if ns is not None else 1)


def _rope_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["rope"] == "truncated":
        return "--rope-init truncated_normal"
    return "--rope-init zeros"

# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule all:
    input:
        expand(
            os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "visualization", "summary_stats.parquet"),
            density=DENSITIES,
            run_name=list(ALL_RUNS.keys()),
        ),
        os.path.join(OUTPUT_DIR, "summary", "epoch_logs.parquet"),
        # expand(
        #     os.path.join(OUTPUT_DIR, "summary", "{group}.pdf"),
        #     group=list(_GROUP_RUNS.keys()),
        # ),
        # expand(
        #     os.path.join(OUTPUT_DIR, "summary", "{group}_loss_curves.pdf"),
        #     group=list(_GROUP_RUNS.keys()),
        # ),


rule overfit_single:
    """Fine-tune AlphaGenome on a single density-tier interval for overfitting experiments."""
    wildcard_constraints:
        density  = "|".join(DENSITIES),
        run_name = "|".join(ALL_RUNS.keys()),
    input:
        weights        = config["alphagenome_pytorch"]["paths"]["weights"],
        genome         = config["gencode"]["paths"]["fasta"],
        gtf_parquet    = config["gencode"]["paths"]["gtf_parquet"],
        bed            = os.path.join(SINGLE_BED_DIR, "{density}.bed"),
        bigwigs        = [
            os.path.join(DATA_DIR, "STAR", sample,
                         "paper_pass.Aligned.sortedByCoord.out.filtered." + strand + ".bw")
            for sample in SAMPLES
            for strand in BIGWIG_STRANDS
        ],
        star_junctions = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.SJ.out.tab")
            for sample in SAMPLES
        ],
        ssu_parquets = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.ssu.parquet")
            for sample in SAMPLES
        ],
    output:
        checkpoint = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth"),
    params:
        num_gpus                    = 1,
        modality_bigwig             = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_bigwig"],
        modality_splicing           = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_splicing"],
        sequence_length             = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
        overlap_highres             = 1024,
        lr                          = 1e-3,
        epochs                      = 50,
        batch_size                  = 1,
        gradient_accumulation_steps = 1,
        track_means_samples         = config["finetuning"]["alphagenome"]["sf3b1mut"]["track_means_samples"],
        save_every                  = 9999,
        output_dir                  = os.path.join(OUTPUT_DIR, "{density}"),
        modality_weights            = _modality_weights,
        pretrained_head_arg         = _pretrained_head_arg,
        gtf_arg                     = _gtf_arg,
        num_segments_arg            = _num_segments_arg,
        rope_arg                    = _rope_arg,
    threads: 6
    resources:
        gres      = "gpu:7g.80gb:1",
        partition = "gpu",
        runtime   = 12 * 60,
        memory    = 80,
        nodelist  = "genoa64-09",
    conda:
        "alphagenome_pytorch"
    retries: 0
    shell:
        """
        set -eo pipefail
        export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

        FINETUNE_SCRIPT=$(mktemp /tmp/finetune_XXXXXX.py)
        cp {FINETUNE_SCRIPT} "$FINETUNE_SCRIPT"

        torchrun --nproc_per_node={params.num_gpus} "$FINETUNE_SCRIPT" \
            --num-workers {threads} \
            --mode linear-probe \
            --modality-weights "{params.modality_weights}" \
            --genome {input.genome} \
            --modality {params.modality_bigwig} --bigwig {input.bigwigs} \
            --modality {params.modality_splicing} --star-junctions {input.star_junctions} --ssu {input.ssu_parquets} \
            --train-bed {input.bed} \
            --val-bed {input.bed} \
            --pretrained-weights {input.weights} \
            --gradient-checkpointing \
            --resume auto \
            --lr {params.lr} \
            --warmup-steps 0 \
            --lr-schedule constant \
            --batch-size {params.batch_size} \
            --gradient-accumulation-steps {params.gradient_accumulation_steps} \
            --epochs {params.epochs} \
            --output-dir {params.output_dir} \
            --sequence-length {params.sequence_length} \
            --track-means-samples {params.track_means_samples} \
            --save-every {params.save_every} \
            --run-name {wildcards.run_name} \
            --max-grad-norm inf \
            --seed 1234 \
            {params.pretrained_head_arg} \
            {params.gtf_arg} \
            {params.num_segments_arg} \
            {params.rope_arg}

        rm -f "$FINETUNE_SCRIPT"

        find "{params.output_dir}/{wildcards.run_name}" -name "*.pth" ! -name "best_model.pth" -delete

        echo "Done!"
        """


rule visualize_single:
    """Visualize predictions vs real tracks for genes overlapping the overfitting interval."""
    wildcard_constraints:
        density  = "|".join(DENSITIES),
        run_name = "|".join(ALL_RUNS.keys()),
    input:
        checkpoint     = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth"),
        bed            = os.path.join(SINGLE_BED_DIR, "{density}.bed"),
        genome         = config["gencode"]["paths"]["fasta"],
        gtf            = config["gencode"]["paths"]["gtf"],
        gtf_parquet    = config["gencode"]["paths"]["gtf_parquet"],
        bigwigs        = [
            os.path.join(DATA_DIR, "STAR", sample,
                         "paper_pass.Aligned.sortedByCoord.out.filtered." + strand + ".bw")
            for sample in SAMPLES
            for strand in BIGWIG_STRANDS
        ],
        star_junctions = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.SJ.out.tab")
            for sample in SAMPLES
        ],
        ssu_parquets = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.ssu.parquet")
            for sample in SAMPLES
        ],
    output:
        summary = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "visualization", "summary_stats.parquet"),
    params:
        script    = "src/scripts/visualize_overfit.py",
        sequence_length = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
        viz_dir   = lambda wildcards: os.path.join(
            OUTPUT_DIR, wildcards.density, wildcards.run_name, "visualization"
        ),
        gtf_arg   = lambda wildcards, input: (
            "--gtf-splice-sites {}".format(input.gtf_parquet)
            if ALL_RUNS[wildcards.run_name]["use_gtf"]
            else ""
        ),
    conda:
        "alphagenome_pytorch"
    shell:
        """
        mkdir -p {params.viz_dir}
        python {params.script} \
            --checkpoint {input.checkpoint} \
            --bed {input.bed} \
            --genome {input.genome} \
            --gtf {input.gtf} \
            --bigwig {input.bigwigs} \
            --star-junctions {input.star_junctions} \
            --ssu {input.ssu_parquets} \
            --sequence-length {params.sequence_length} \
            --output-dir {params.viz_dir} \
            {params.gtf_arg}
        """

rule combine_epoch_logs:
    input:
        logs = lambda wildcards: expand(
            os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "epoch_log.csv"),
            density=DENSITIES,
            run_name=list(ALL_RUNS.keys()),
        )
    output:
        combined = os.path.join(OUTPUT_DIR, "summary", "epoch_logs.parquet")
    threads: 1
    run:
        import pandas as pd

        combined = pd.concat([
            (
                pd.read_csv(f)
                .assign(
                    density = os.path.basename(os.path.dirname(os.path.dirname(f))),
                    run_name = os.path.basename(os.path.dirname(f))
                )
            )
            for f in input.logs
        ])

        combined.to_parquet(output.combined, index=False, compression="zstd")

        print("Done!")

