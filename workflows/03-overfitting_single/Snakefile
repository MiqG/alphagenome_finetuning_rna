"""
Overfitting workflow: fine-tune AlphaGenome on a single medium-density interval.

Depends on outputs from 02-preprocess_data (data/prep/overfitting/single/{density}.bed).
Each interval is overfitted independently for 1000 epochs (constant LR, linear-probe mode)
using paper_pass bigwigs and junction files from the 2 preprocessing samples.

Three experiment groups, each run on the medium density interval:

  original            — baseline (randinit, no segmented loss, no GTF):
                        1 modality-weight config x 2 dtypes

  debug_splice_sites  — ablate head_init x segmented_loss x GTF:
                        6 configs x 2 dtypes

  debug_splice_junctions — ablate rope x loss x junction_source x head_init:
                        3 losses (original, normalized, sparse) x 2 rope x 2 source x 2 init
                        = 24 configs x 2 dtypes

Run with:
    snakemake -s workflows/03-overfitting_single/Snakefile --use-conda [-n]
"""

import os

configfile: "config/config.yaml"

DATA_DIR        = config["rnaseq"]["sf3b1mut"]["path"]
FINETUNE_SCRIPT = config["finetuning"]["alphagenome"]["finetune_script"]
SINGLE_BED_DIR  = config["preprocessing"]["overfitting"]["single"]["output_dir"]
OUTPUT_DIR      = "results/finetuning/alphagenome_pytorch/overfitting/single"

SAMPLES        = config["preprocessing"]["overfitting"]["samples"]
DENSITIES      = ["medium"]
DTYPES         = ["bfloat16"] #["bfloat16", "float32"]
BIGWIG_STRANDS = ["forward", "reverse"]
RUN_NAMES_OI = []

# ---------------------------------------------------------------------------
# Run configuration
# Each entry: modality_weights, init_strategy, use_gtf, loss_partitions, rope
# ---------------------------------------------------------------------------

_ALL_MW = "rna_seq:1.0,splice_site:1.0,splice_usage:1.0,splice_junctions:1.0"
_ORIGINAL_RUNS = {
    "original__all": {
        "modality_weights": _ALL_MW,
        "init_strategy": "normal",
        "use_gtf": False,
        "num_segments": None,
        "rope": "original",
    }
}

# 6 (head_init x segmented_loss x gtf_variant) configs x 2 modality-weight sets
_SS_CONFIGS = [
    ("randinit_noseg_gtf",  "normal",     None, True),
    ("randinit_seg_gtf",    "normal",     8,    True),
    ("randinit_seg_nogtf",  "normal",     8,    False),
    ("pretrinit_seg_nogtf", "pretrained", 8,    False),
    ("pretrinit_seg_gtf",   "pretrained", 8,    True),
    ("pretrinit_noseg_gtf", "pretrained", None, True),
]

_DEBUG_SS_RUNS = {}
for _cfg, _init, _ns, _gtf in _SS_CONFIGS:
    for _mod_suffix, _mw in [("all", _ALL_MW)]:#, ("splice_site_only", _SS_MW)]:
        _key = "debug_splice_sites__{}__{}" .format(_cfg, _mod_suffix)
        _DEBUG_SS_RUNS[_key] = {
            "modality_weights": _mw,
            "init_strategy":    _init,
            "use_gtf":          _gtf,
            "num_segments":     _ns,
            "rope":             "original",
        }

# 4-way factorial: rope x loss x junction_position_source x junction_head_init (16 runs)
# GTF never used. When source=="predicted", splice_site head always gets pretrained weights (idx 0).
_SJ_ROPE_OPTIONS   = [("origrope",  "original"),   ("truncrope",  "truncated")]
_SJ_LOSS_OPTIONS   = [("origloss",  "original"),   ("newloss",    "normalized"), ("sparseloss", "sparse")]
_SJ_SOURCE_OPTIONS = [("annotated", "annotated"),  ("predicted",  "predicted")]
_SJ_JINIT_OPTIONS  = [("randinit",  "normal"),     ("pretrinit",  "pretrained")]

_DEBUG_SJ_RUNS = {}
for _rope_cfg, _rope in _SJ_ROPE_OPTIONS:
    for _loss_suffix, _loss in _SJ_LOSS_OPTIONS:
        for _src_suffix, _src in _SJ_SOURCE_OPTIONS:
            for _jinit_suffix, _jinit in _SJ_JINIT_OPTIONS:
                _key = "debug_splice_junctions__{}__{}__{}__{}" .format(
                    _rope_cfg, _loss_suffix, _src_suffix, _jinit_suffix
                )
                _DEBUG_SJ_RUNS[_key] = {
                    "modality_weights":         _ALL_MW,
                    "use_gtf":                  False,
                    "num_segments":             None,
                    "rope":                     _rope,
                    "junction_loss":            _loss,
                    "junction_position_source": _src,
                    "junction_head_init":       _jinit,
                }


def _add_dtype_variants(runs):
    result = {}
    for key, cfg in runs.items():
        for dtype in DTYPES:
            result["{}__{}" .format(key, dtype)] = dict(cfg, dtype=dtype)
    return result

_ORIGINAL_RUNS = _add_dtype_variants(_ORIGINAL_RUNS)
_DEBUG_SS_RUNS = _add_dtype_variants(_DEBUG_SS_RUNS)
_DEBUG_SJ_RUNS = _add_dtype_variants(_DEBUG_SJ_RUNS)

ALL_RUNS = {}
ALL_RUNS.update(_ORIGINAL_RUNS)
ALL_RUNS.update(_DEBUG_SS_RUNS)
ALL_RUNS.update(_DEBUG_SJ_RUNS)
#print(list(ALL_RUNS.keys()))

_GROUP_RUNS = {
    "original":               list(_ORIGINAL_RUNS.keys()),
    "debug_splice_sites":     list(_DEBUG_SS_RUNS.keys()),
    "debug_splice_junctions": list(_DEBUG_SJ_RUNS.keys()),
}

# ---------------------------------------------------------------------------
# Parameter helper functions
# ---------------------------------------------------------------------------

def _modality_weights(wildcards):
    return ALL_RUNS[wildcards.run_name]["modality_weights"]


def _pretrained_head_arg(wildcards):
    run = ALL_RUNS[wildcards.run_name]
    # splice_site pretrained(0): when using predicted junction source, or when SS debug uses pretrained init
    ss = "0" if (run.get("junction_position_source") == "predicted" or run.get("init_strategy") == "pretrained") else "NA"
    # splice_junctions: single broadcast index, per-sample indices, or random
    jinit = run.get("junction_head_init", "normal")
    if jinit == "pretrained":
        sj = "139"
    elif jinit == "pretrained_persample":
        sj = r"139\|191"  # one pretrained tissue index per sample; breaks slot symmetry
    else:
        sj = "NA"
    return (
        "--pretrained-head-samples rna_seq:NA,splice_usage:NA,splice_junctions:{},splice_site:{}"
        " --organism human"
    ).format(sj, ss)


def _mode_arg(wildcards):
    return "--mode linear-probe"


def _gtf_arg(wildcards, input):
    if ALL_RUNS[wildcards.run_name]["use_gtf"]:
        return "--gtf {}".format(input.gtf_parquet)
    return ""


def _num_segments_arg(wildcards):
    ns = ALL_RUNS[wildcards.run_name]["num_segments"]
    return "--num-segments {}".format(ns if ns is not None else 1)


def _rope_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["rope"] == "truncated":
        return "--rope-init truncated_normal"
    return "--rope-init zeros"


def _new_loss_arg(wildcards):
    jl = ALL_RUNS[wildcards.run_name].get("junction_loss", "original")
    return "--junction-loss {}".format(jl)


def _junction_position_source_arg(wildcards):
    src = ALL_RUNS[wildcards.run_name].get("junction_position_source", "annotated")
    return "--junction-position-source {}".format(src)


def _dtype_arg(wildcards):
    return "--dtype {}".format(ALL_RUNS[wildcards.run_name]["dtype"])


def _no_amp_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["dtype"] == "float32":
        return "--no-amp"
    return ""


def _lr(wildcards):
    return ALL_RUNS[wildcards.run_name].get("lr", 1e-3)

# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule all:
    input:
        expand(
            os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth"),
            density=DENSITIES,
            run_name=list(ALL_RUNS.keys()),
        ),
        os.path.join(OUTPUT_DIR, "summary", "epoch_logs.parquet"),
        # expand(
        #     os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "rna_seq.npz"),
        #     density=DENSITIES,
        #     run_name=RUN_NAMES_OI,
        # ),



rule overfit_single:
    """Fine-tune AlphaGenome on a single density-tier interval for overfitting experiments."""
    wildcard_constraints:
        density  = "|".join(DENSITIES),
        run_name = "|".join(ALL_RUNS.keys()),
    input:
        weights        = ancient(config["alphagenome_pytorch"]["paths"]["weights"]),
        genome         = config["gencode"]["paths"]["fasta"],
        gtf_parquet    = config["gencode"]["paths"]["gtf_parquet"],
        bed            = os.path.join(SINGLE_BED_DIR, "{density}.bed"),
        bigwigs        = [
            os.path.join(DATA_DIR, "STAR", sample,
                         "paper_pass.Aligned.sortedByCoord.out.filtered." + strand + ".bw")
            for sample in SAMPLES
            for strand in BIGWIG_STRANDS
        ],
        star_junctions = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.SJ.out.tab")
            for sample in SAMPLES
        ],
        ssu_parquets = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.ssu.parquet")
            for sample in SAMPLES
        ],
    output:
        checkpoint = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth")
    params:
        num_gpus                    = 1,
        modality_bigwig             = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_bigwig"],
        modality_splicing           = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_splicing"],
        sequence_length             = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
        lr                          = _lr,
        weight_decay                = 0,
        warmup_steps                = 0,
        epochs                      = 500,
        save_every                  = 250,
        batch_size                  = 1,
        gradient_accumulation_steps = 1,
        track_means_samples         = config["finetuning"]["alphagenome"]["sf3b1mut"]["track_means_samples"],
        output_dir                  = os.path.join(OUTPUT_DIR, "{density}"),
        modality_weights            = _modality_weights,
        pretrained_head_arg         = _pretrained_head_arg,
        gtf_arg                     = _gtf_arg,
        num_segments_arg            = _num_segments_arg,
        rope_arg                    = _rope_arg,
        new_loss_arg                = _new_loss_arg,
        junction_position_source_arg = _junction_position_source_arg,
        dtype_arg                    = _dtype_arg,
        no_amp_arg                   = _no_amp_arg,
        mode_arg                     = _mode_arg,
    threads: 20
    resources:
        runtime = int(4*60),  # hours in minutes
        gres = "gpu:1",
        partition = "acc_ehpc",
        qos = "acc_ehpc"
    conda:
        "alphagenome_pytorch"
    retries: 1
    shell:
        """
        set -eo pipefail
        export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

        FINETUNE_SCRIPT=$(mktemp /tmp/finetune_XXXXXX.py)
        cp {FINETUNE_SCRIPT} "$FINETUNE_SCRIPT"

        MASTER_PORT=$(python -c "import socket; s=socket.socket(); s.bind(('',0)); print(s.getsockname()[1]); s.close()")

        torchrun --nproc_per_node={params.num_gpus} --master_port "$MASTER_PORT" "$FINETUNE_SCRIPT" \
            --num-workers {threads} \
            {params.mode_arg} \
            --modality-weights "{params.modality_weights}" \
            --genome {input.genome} \
            --modality {params.modality_bigwig} --bigwig {input.bigwigs} \
            --modality {params.modality_splicing} --star-junctions {input.star_junctions} --ssu {input.ssu_parquets} \
            --train-bed {input.bed} \
            --val-bed {input.bed} \
            --pretrained-weights {input.weights} \
            --gradient-checkpointing \
            --resume auto \
            --lr {params.lr} \
            --warmup-steps {params.warmup_steps} \
            --lr-schedule constant \
            --weight-decay {params.weight_decay} \
            --batch-size {params.batch_size} \
            --gradient-accumulation-steps {params.gradient_accumulation_steps} \
            --epochs {params.epochs} \
            --output-dir {params.output_dir} \
            --sequence-length {params.sequence_length} \
            --track-means-samples {params.track_means_samples} \
            --save-every {params.save_every} \
            --run-name {wildcards.run_name} \
            --max-grad-norm 1.0 \
            --seed 1234 \
            {params.pretrained_head_arg} \
            {params.gtf_arg} \
            {params.num_segments_arg} \
            {params.rope_arg} \
            {params.new_loss_arg} \
            {params.junction_position_source_arg} \
            {params.dtype_arg} \
            {params.no_amp_arg}

        rm -f "$FINETUNE_SCRIPT"

        find "{params.output_dir}/{wildcards.run_name}" -name "*.pth" ! -name "best_model.pth" -printf "%T@ %p\n" \
            | sort -n | head -n -1 | awk '{{print $2}}' | xargs -r rm -f

        echo "Done!"
        """

rule combine_epoch_logs:
    params:
        logs = lambda wildcards: expand(
            os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "epoch_log.csv"),
            run_name=list(ALL_RUNS.keys()),
            density=DENSITIES
        )
    input:
        models = lambda wildcards: expand(
            os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth"),
            run_name=list(ALL_RUNS.keys()),
            density=DENSITIES
        )
    output:
        combined = os.path.join(OUTPUT_DIR, "summary", "epoch_logs.parquet")
    threads: 1
    resources:
        runtime = int(0.1*60),  # hours in minutes
        gres = "none",
        partition = "gpp",
        qos = "gp_ehpc"
    run:
        import pandas as pd

        combined = pd.concat([
            (
                pd.read_csv(f)
                .assign(
                    run_name = os.path.basename(os.path.dirname(f)),
                    density = os.path.basename(os.path.dirname(os.path.dirname(f)))
                )
            )
            for f in params.logs
        ])

        combined.to_parquet(output.combined, index=False, compression="zstd")

        print("Done!")

rule finetuned_forward_pass_single:
    """Run fine-tuned AlphaGenome forward pass on each single density interval for runs of interest."""
    wildcard_constraints:
        density  = "|".join(DENSITIES),
        run_name = "|".join(RUN_NAMES_OI),
    input:
        bed        = os.path.join(SINGLE_BED_DIR, "{density}.bed"),
        weights    = config["alphagenome_pytorch"]["paths"]["weights"],
        genome     = config["gencode"]["paths"]["fasta"],
        checkpoint = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "best_model.pth"),
    output:
        rna_seq        = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "rna_seq.npz"),
        classification = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "splice_classification.npz"),
        usage          = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "splice_usage.npz"),
        junctions      = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "splice_junctions.npz"),
        metadata       = os.path.join(OUTPUT_DIR, "{density}", "{run_name}", "metadata.json"),
    params:
        script  = "src/scripts/run_pretrained_forward_pass.py",
        out_dir = os.path.join(OUTPUT_DIR, "{density}", "{run_name}"),
        seq_len = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
    threads: 4
    resources:
        runtime   = int(0.5 * 60),
        gres      = "gpu:1",
        partition = "acc_ehpc",
        qos       = "acc_ehpc"
    conda:
        "alphagenome_pytorch"
    shell:
        """
        python {params.script} \
            --weights {input.weights} \
            --checkpoint {input.checkpoint} \
            --bed {input.bed} \
            --genome {input.genome} \
            --sequence-length {params.seq_len} \
            --output-dir {params.out_dir}
        """