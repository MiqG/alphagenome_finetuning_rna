"""
Overfitting workflow: fine-tune AlphaGenome on the dev dataset (train/val split).

Depends on outputs from 02-preprocess_data (data/prep/overfitting/dev/train.bed,
data/prep/overfitting/dev/valid.bed).

One experiment group (debug_splice_junctions) with 4 runs total:
  2 configs (truncrope_origloss, truncrope_newloss) x
  2 modality-weight sets (junction_only, all)

Run with:
    snakemake -s workflows/04-overfitting_dev/Snakefile --use-conda [-n]
"""

import os

configfile: "config/config.yaml"

DATA_DIR        = config["rnaseq"]["sf3b1mut"]["path"]
FINETUNE_SCRIPT = config["finetuning"]["alphagenome"]["finetune_script"]
DEV_BED_DIR     = config["preprocessing"]["overfitting"]["dev"]["output_dir"]
OUTPUT_DIR      = "results/finetuning/alphagenome_pytorch/overfitting/dev"

SAMPLES        = config["preprocessing"]["overfitting"]["samples"]
BIGWIG_STRANDS = ["forward", "reverse"]

# ---------------------------------------------------------------------------
# Run configuration
# Each entry: modality_weights, init_strategy, use_gtf, loss_partitions,
#             rope, new_junction_loss
# ---------------------------------------------------------------------------

_ALL_MW = "rna_seq:1.0,splice_site:1.0,splice_usage:1.0,splice_junctions:1.0"
_SJ_MW  = "rna_seq:0.0,splice_site:0.0,splice_usage:0.0,splice_junctions:1.0"

# 2 (loss_variant) configs x 2 modality-weight sets
_SJ_CONFIGS = [
    ("truncrope_origloss", False),
    ("truncrope_newloss",  True),
]

_DEBUG_SJ_RUNS = {}
for _cfg, _new_loss in _SJ_CONFIGS:
    for _mod_suffix, _mw in [("junction_only", _SJ_MW), ("all", _ALL_MW)]:
        _key = "debug_splice_junctions__{}__{}" .format(_cfg, _mod_suffix)
        _DEBUG_SJ_RUNS[_key] = {
            "modality_weights":  _mw,
            "init_strategy":     "normal",
            "use_gtf":           False,
            "loss_partitions":   None,
            "rope":              "truncated",
            "new_junction_loss": _new_loss,
        }

ALL_RUNS = {}
ALL_RUNS.update(_DEBUG_SJ_RUNS)

_GROUP_RUNS = {
    "debug_splice_junctions": list(_DEBUG_SJ_RUNS.keys()),
}


# ---------------------------------------------------------------------------
# Parameter helper functions
# ---------------------------------------------------------------------------

def _modality_weights(wildcards):
    return ALL_RUNS[wildcards.run_name]["modality_weights"]


def _pretrained_head_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["init_strategy"] == "pretrained":
        return (
            "--pretrained-head-samples rna_seq:119,splice_usage:139,splice_junctions:139,splice_site:0"
            " --organism human"
        )
    return "--pretrained-head-samples rna_seq:NA,splice_usage:NA,splice_junctions:NA,splice_site:NA --organism human"


def _gtf_arg(wildcards, input):
    if ALL_RUNS[wildcards.run_name]["use_gtf"]:
        return "--gtf {}".format(input.gtf_parquet)
    return ""


def _loss_partitions_arg(wildcards):
    lp = ALL_RUNS[wildcards.run_name]["loss_partitions"]
    if lp is not None:
        return "--loss-partitions {}".format(lp)
    return ""


def _rope_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["rope"] == "truncated":
        return "--rope-init truncated_normal"
    return "--rope-init zeros"


def _new_loss_arg(wildcards):
    if ALL_RUNS[wildcards.run_name]["new_junction_loss"]:
        return "--junction-loss normalized"
    return "--junction-loss original"


# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule all:
    input:
        expand(
            os.path.join(OUTPUT_DIR, "{run_name}", "visualization", "summary_stats.parquet"),
            run_name=list(ALL_RUNS.keys()),
        ),
        expand(
            os.path.join(OUTPUT_DIR, "summary", "{group}.pdf"),
            group=list(_GROUP_RUNS.keys()),
        ),


rule overfit_dev:
    """Fine-tune AlphaGenome on the dev dataset (train/val split) for overfitting experiments."""
    wildcard_constraints:
        run_name = "|".join(ALL_RUNS.keys()),
    input:
        weights        = config["alphagenome_pytorch"]["paths"]["weights"],
        genome         = config["gencode"]["paths"]["fasta"],
        gtf_parquet    = config["gencode"]["paths"]["gtf_parquet"],
        train_bed      = os.path.join(DEV_BED_DIR, "train.bed"),
        val_bed        = os.path.join(DEV_BED_DIR, "valid.bed"),
        bigwigs        = [
            os.path.join(DATA_DIR, "STAR", sample,
                         "paper_pass.Aligned.sortedByCoord.out.filtered." + strand + ".bw")
            for sample in SAMPLES
            for strand in BIGWIG_STRANDS
        ],
        star_junctions = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.SJ.out.tab")
            for sample in SAMPLES
        ],
        ssu_parquets = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.ssu.parquet")
            for sample in SAMPLES
        ],
    output:
        checkpoint = os.path.join(OUTPUT_DIR, "{run_name}", "best_model.pth"),
    params:
        num_gpus                    = 1,
        modality_bigwig             = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_bigwig"],
        modality_splicing           = config["finetuning"]["alphagenome"]["sf3b1mut"]["modality_splicing"],
        sequence_length             = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
        overlap_highres             = 1024,
        lr                          = 1e-3,
        epochs                      = 50,
        batch_size                  = 1,
        gradient_accumulation_steps = 1,
        track_means_samples         = config["finetuning"]["alphagenome"]["sf3b1mut"]["track_means_samples"],
        save_every_steps            = 50,
        output_dir                  = OUTPUT_DIR,
        modality_weights            = _modality_weights,
        pretrained_head_arg         = _pretrained_head_arg,
        gtf_arg                     = _gtf_arg,
        loss_partitions_arg         = _loss_partitions_arg,
        rope_arg                    = _rope_arg,
        new_loss_arg                = _new_loss_arg,
    threads: 6
    resources:
        gres      = "gpu:7g.80gb:1",
        partition = "gpu",
        runtime   = 12 * 60,
        memory    = 80,
        nodelist  = "genoa64-09",
    conda:
        "alphagenome_pytorch"
    retries: 0
    shell:
        """
        set -eo pipefail
        export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

        FINETUNE_SCRIPT=$(mktemp /tmp/finetune_XXXXXX.py)
        cp {FINETUNE_SCRIPT} "$FINETUNE_SCRIPT"

        torchrun --nproc_per_node={params.num_gpus} "$FINETUNE_SCRIPT" \
            --num-workers {threads} \
            --mode linear-probe \
            --modality-weights "{params.modality_weights}" \
            --genome {input.genome} \
            --modality {params.modality_bigwig} --bigwig {input.bigwigs} \
            --modality {params.modality_splicing} --star-junctions {input.star_junctions} --ssu {input.ssu_parquets} \
            --train-bed {input.train_bed} \
            --val-bed {input.val_bed} \
            --pretrained-weights {input.weights} \
            --gradient-checkpointing \
            --resume auto \
            --lr {params.lr} \
            --warmup-steps 0 \
            --lr-schedule constant \
            --batch-size {params.batch_size} \
            --gradient-accumulation-steps {params.gradient_accumulation_steps} \
            --epochs {params.epochs} \
            --output-dir {params.output_dir} \
            --sequence-length {params.sequence_length} \
            --track-means-samples {params.track_means_samples} \
            --save-every-steps {params.save_every_steps} \
            --run-name {wildcards.run_name} \
            --max-grad-norm inf \
            --seed 1234 \
            {params.pretrained_head_arg} \
            {params.gtf_arg} \
            {params.loss_partitions_arg} \
            {params.rope_arg} \
            {params.new_loss_arg}

        rm -f "$FINETUNE_SCRIPT"

        find "{params.output_dir}/{wildcards.run_name}" -name "*.pth" ! -name "best_model.pth" -delete

        echo "Done!"
        """


rule visualize_dev:
    """Visualize predictions vs real tracks for genes overlapping the dev val intervals."""
    wildcard_constraints:
        run_name = "|".join(ALL_RUNS.keys()),
    input:
        checkpoint     = os.path.join(OUTPUT_DIR, "{run_name}", "best_model.pth"),
        bed            = os.path.join(DEV_BED_DIR, "valid.bed"),
        genome         = config["gencode"]["paths"]["fasta"],
        gtf            = config["gencode"]["paths"]["gtf"],
        gtf_parquet    = config["gencode"]["paths"]["gtf_parquet"],
        bigwigs        = [
            os.path.join(DATA_DIR, "STAR", sample,
                         "paper_pass.Aligned.sortedByCoord.out.filtered." + strand + ".bw")
            for sample in SAMPLES
            for strand in BIGWIG_STRANDS
        ],
        star_junctions = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.SJ.out.tab")
            for sample in SAMPLES
        ],
        ssu_parquets = [
            os.path.join(DATA_DIR, "STAR", sample, "paper_pass.ssu.parquet")
            for sample in SAMPLES
        ],
    output:
        summary = os.path.join(OUTPUT_DIR, "{run_name}", "visualization", "summary_stats.parquet"),
    params:
        script          = "src/scripts/visualize_overfit.py",
        sequence_length = config["finetuning"]["alphagenome"]["sf3b1mut"]["sequence_length"],
        viz_dir         = lambda wildcards: os.path.join(
            OUTPUT_DIR, wildcards.run_name, "visualization"
        ),
        gtf_arg         = lambda wildcards, input: (
            "--gtf-splice-sites {}".format(input.gtf_parquet)
            if ALL_RUNS[wildcards.run_name]["use_gtf"]
            else ""
        ),
    conda:
        "alphagenome_pytorch"
    shell:
        """
        mkdir -p {params.viz_dir}
        python {params.script} \
            --checkpoint {input.checkpoint} \
            --bed {input.bed} \
            --genome {input.genome} \
            --gtf {input.gtf} \
            --bigwig {input.bigwigs} \
            --star-junctions {input.star_junctions} \
            --sequence-length {params.sequence_length} \
            --output-dir {params.viz_dir} \
            {params.gtf_arg}
        """


rule plot_group_summary:
    """Plot training dynamics and junction correlations for all runs in the experiment group."""
    wildcard_constraints:
        group = "|".join(_GROUP_RUNS.keys()),
    input:
        summaries = lambda wildcards: expand(
            os.path.join(OUTPUT_DIR, "{run_name}", "visualization", "summary_stats.parquet"),
            run_name=_GROUP_RUNS[wildcards.group],
        ),
    output:
        pdf = os.path.join(OUTPUT_DIR, "summary", "{group}.pdf"),
    params:
        script   = "src/scripts/plot_overfit_summary.py",
        run_dirs = lambda wildcards: [
            os.path.join(OUTPUT_DIR, run_name)
            for run_name in _GROUP_RUNS[wildcards.group]
        ],
    conda:
        "alphagenome_pytorch"
    shell:
        """
        mkdir -p "$(dirname {output.pdf})"
        python {params.script} \
            --run-dirs {params.run_dirs} \
            --output {output.pdf}
        """
